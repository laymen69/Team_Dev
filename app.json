{
  "expo": {
    "name": "MerchandisingTeam",
    "slug": "merchandising-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/apps.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/web.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.teamdev.merchandisingteam"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/merch.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.teamdev.merchandisingteam"
    },
    "web": {
      "favicon": "./assets/images/merch.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff",
          "sounds": []
        }
      ]
    ],
    "scheme": "merchandisingteam",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}